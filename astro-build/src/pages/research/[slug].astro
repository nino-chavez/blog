---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { generateArticleSchema } from '../../utils/schema';
import ReadingProgress from '../../components/ReadingProgress';

// In SSR mode, get the research note from the slug parameter
const { slug } = Astro.params;
const researchNotes = await getCollection('research-notes');
const note = researchNotes.find((n) => n.id === slug);

if (!note) {
  return Astro.redirect('/research');
}

// Only show published research notes
if (note.data.visibility !== 'published') {
  return Astro.redirect('/research');
}

const { Content } = await render(note);

// Generate JSON-LD schema
const articleSchema = generateArticleSchema({
  id: `research/${note.id}`,
  data: note.data,
});

// Format dates
const publishedDate = new Date(note.data.publishedAt);
const formattedDate = publishedDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Calculate reading time
const wordCount = note.body?.split(/\s+/).length || 0;
const readingTime = Math.ceil(wordCount / 200);

// Note type labels
const noteTypeLabels: Record<string, string> = {
  'red-team-analysis': 'Red Team Analysis',
  'research-synthesis': 'Research Synthesis',
  'literature-review': 'Literature Review',
  'methodology': 'Methodology',
  'data-analysis': 'Data Analysis',
  'interview-notes': 'Interview Notes',
  'market-research': 'Market Research',
};

const noteTypeLabel = noteTypeLabels[note.data.noteType] || 'Research Note';

// Origin labels
const originLabels: Record<string, string> = {
  'internal': 'Signal Dispatch Research',
  'external': 'External Analysis',
  'collaborative': 'Collaborative Research',
};

const originLabel = originLabels[note.data.origin] || 'Research';
---

<BaseLayout
  title={note.data.title}
  description={note.data.excerpt || `Research note by Nino Chavez`}
  type="article"
  publishedTime={publishedDate.toISOString()}
  author={note.data.author}
  jsonLd={[articleSchema]}
>
  <!-- Reading Progress Bar -->
  <ReadingProgress client:load />

  <main class="min-h-screen">
    <SiteHeader currentPage="research" />

    <div class="max-w-4xl mx-auto px-4 py-12">
      <!-- Back link -->
      <a
        href="/research"
        class="group inline-flex items-center gap-2 text-zinc-400 hover:text-athletic-court-orange transition-all duration-150 font-medium mb-8 no-print"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Research
      </a>

      <article class="space-y-8">
        <!-- Article Header -->
        <header class="space-y-4 pb-8 border-b border-zinc-800/50">
          <div class="flex items-center gap-3 text-sm flex-wrap">
            <span class="font-bold uppercase tracking-wider px-3 py-1.5 rounded-full border transition-colors bg-amber-500/10 border-amber-500/30 text-amber-500">
              {noteTypeLabel}
            </span>
            <span class="text-zinc-700">•</span>
            <span class="text-zinc-500">{originLabel}</span>
            <span class="text-zinc-700">•</span>
            <time datetime={publishedDate.toISOString()} class="text-zinc-500">
              {formattedDate}
            </time>
            <span class="text-zinc-700">•</span>
            <span class="flex items-center gap-1.5 text-zinc-500">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {readingTime} min read
            </span>
          </div>

          <h1 class="text-3xl md:text-4xl lg:text-5xl font-black text-white leading-tight tracking-tight">
            {note.data.title}
          </h1>

          {note.data.excerpt && (
            <p class="text-xl text-zinc-400 leading-relaxed">
              {note.data.excerpt}
            </p>
          )}

          {note.data.externalSource && (
            <div class="p-4 rounded-xl bg-zinc-900/50 border border-zinc-800">
              <p class="text-sm text-zinc-400">
                <strong class="text-zinc-300">Source:</strong> {note.data.externalSource.name}
                {note.data.externalSource.organization && ` (${note.data.externalSource.organization})`}
                {note.data.externalSource.receivedAt && (
                  <span class="text-zinc-500"> • Received {new Date(note.data.externalSource.receivedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
                )}
              </p>
            </div>
          )}

          <div class="flex items-center gap-3 pt-4">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-amber-500 to-athletic-court-orange flex items-center justify-center text-white font-bold">
              NC
            </div>
            <div>
              <p class="text-white font-medium">{note.data.author || 'Nino Chavez'}</p>
              <p class="text-zinc-500 text-sm">Signal Dispatch Research</p>
            </div>
          </div>
        </header>

        <!-- Supports Content -->
        {note.data.supportsContent && note.data.supportsContent.length > 0 && (
          <div class="p-4 rounded-xl bg-zinc-900/50 border border-zinc-800 no-print">
            <p class="text-sm text-zinc-400 mb-2">
              <strong class="text-zinc-300">This research supports:</strong>
            </p>
            <div class="flex flex-wrap gap-2">
              {note.data.supportsContent.map((content) => {
                const basePath = content.type === 'blog' ? '/blog' : content.type === 'whitepaper' ? '/blog/whitepapers' : '/blog/presentations';
                return (
                  <a
                    href={`${basePath}/${content.slug}`}
                    class="text-sm px-3 py-1 rounded-full bg-zinc-800 text-zinc-300 hover:bg-zinc-700 hover:text-white transition-colors"
                  >
                    {content.type}: {content.slug}
                  </a>
                );
              })}
            </div>
          </div>
        )}

        <!-- Article Content -->
        <div class="prose prose-lg max-w-none">
          <Content />
        </div>

        <!-- Social Sharing -->
        <div class="pt-8 pb-8 border-t border-zinc-800/50 no-print">
          <div class="flex items-center gap-4">
            <span class="text-zinc-500 text-sm font-medium">Share:</span>
            <a
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(note.data.title)}&url=${encodeURIComponent(`https://ninochavez.co/research/${note.id}`)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-zinc-400 hover:text-white transition-colors"
              title="Share on Twitter"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`https://ninochavez.co/research/${note.id}`)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-zinc-400 hover:text-[#0A66C2] transition-colors"
              title="Share on LinkedIn"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
            <button
              onclick={`navigator.clipboard.writeText('https://ninochavez.co/research/${note.id}'); this.textContent = 'Copied!'`}
              class="text-zinc-400 hover:text-amber-500 transition-colors text-sm"
              title="Copy link"
            >
              Copy link
            </button>
          </div>
        </div>
      </article>
    </div>

    <SiteFooter />
  </main>
</BaseLayout>
