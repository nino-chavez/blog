---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogList from '../../components/BlogList';
import { generateWebsiteSchema, generateBlogSchema, generatePersonSchema } from '../../utils/schema';

// Get all published posts sorted by date
const posts = await getCollection('blog', ({ data }) => data.status !== 'draft');
const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);

// Prepare posts data for BlogList component
const postsData = sortedPosts.map((post) => ({
  id: post.id,
  title: post.data.title,
  excerpt: post.data.excerpt || '',
  publishedAt: typeof post.data.publishedAt === 'string'
    ? post.data.publishedAt
    : post.data.publishedAt.toISOString(),
  category: post.data.category,
  tags: post.data.tags,
  featured: post.data.featured,
  featureImage: post.data.featureImage,
}));

// Generate JSON-LD schemas
const websiteSchema = generateWebsiteSchema();
const blogSchema = generateBlogSchema(sortedPosts);
const personSchema = generatePersonSchema();
---

<BaseLayout
  title="Signal Dispatch"
  description="Architecture, commerce, and the signals that matter. Exploring AI workflows, systems thinking, and leadership through practical experience."
  jsonLd={[websiteSchema, blogSchema, personSchema]}
>
  <main class="min-h-screen">
    <!-- Compact Header -->
    <header class="sticky top-0 z-50 bg-zinc-950/95 backdrop-blur-xl border-b border-zinc-800/30">
      <nav class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-[56px] sm:h-[73px]">
          <!-- Logo -->
          <a href="/blog" class="flex items-center gap-2 sm:gap-3 flex-shrink min-w-0">
            <h1 class="text-sm xs:text-base sm:text-lg font-bold bg-gradient-to-r from-athletic-brand-violet to-athletic-court-orange bg-clip-text text-transparent truncate">
              Signal Dispatch
            </h1>
            <span class="hidden lg:inline text-sm text-zinc-500 truncate">
              · Strategy, insights, and the signals that matter
            </span>
          </a>

          <!-- Right: Links -->
          <div class="flex items-center gap-0.5 xs:gap-1 sm:gap-4 flex-shrink-0">
            <!-- Text links - hidden on mobile, visible on sm+ -->
            <a href="/blog/series" class="hidden sm:block text-sm text-zinc-400 hover:text-white transition-colors">
              Series
            </a>
            <a href="/blog/whitepapers" class="hidden sm:block text-sm text-zinc-400 hover:text-white transition-colors">
              Whitepapers
            </a>
            <a href="/blog/presentations" class="hidden sm:block text-sm text-zinc-400 hover:text-white transition-colors">
              Presentations
            </a>
            <!-- Icon links with touch-friendly sizing -->
            <a href="/blog/series" class="sm:hidden flex items-center justify-center w-9 h-9 rounded-lg text-zinc-400 hover:text-white hover:bg-zinc-800/50 transition-colors" title="Series">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
            </a>
            <a href="/blog/whitepapers" class="sm:hidden flex items-center justify-center w-9 h-9 rounded-lg text-zinc-400 hover:text-white hover:bg-zinc-800/50 transition-colors" title="Whitepapers">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </a>
            <a href="/blog/presentations" class="sm:hidden flex items-center justify-center w-9 h-9 rounded-lg text-zinc-400 hover:text-white hover:bg-zinc-800/50 transition-colors" title="Presentations">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z" />
              </svg>
            </a>
            <a href="/rss.xml" class="flex items-center justify-center w-9 h-9 sm:w-auto sm:h-auto rounded-lg text-zinc-400 hover:text-white hover:bg-zinc-800/50 sm:hover:bg-transparent transition-colors" title="RSS Feed">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7m-6 0a1 1 0 11-2 0 1 1 0 012 0z" />
              </svg>
            </a>
            <a href="https://ninochavez.co" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center w-9 h-9 sm:w-auto sm:h-auto rounded-lg text-zinc-400 hover:text-white hover:bg-zinc-800/50 sm:hover:bg-transparent transition-colors" title="Portfolio">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
        </div>
      </nav>
    </header>

    <!-- Blog Content -->
    <section class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-6 sm:py-8">
      <BlogList posts={postsData} client:load />
    </section>

    <!-- Footer -->
    <footer class="border-t border-zinc-800/50 py-12 mt-8">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row justify-between items-center gap-6">
          <div class="text-center md:text-left">
            <p class="text-zinc-500 text-sm">
              &copy; {new Date().getFullYear()} Nino Chavez. All rights reserved.
            </p>
          </div>
          <div class="flex items-center gap-6">
            <a href="/rss.xml" class="text-zinc-400 hover:text-white text-sm transition-colors">RSS Feed</a>
            <a href="/full-content-rss.xml" class="text-zinc-400 hover:text-white text-sm transition-colors">Full RSS</a>
            <a href="/api/posts.json" class="text-zinc-400 hover:text-white text-sm transition-colors">API</a>
            <a href="/llms.txt" class="text-zinc-400 hover:text-white text-sm transition-colors">llms.txt</a>
            <a href="https://ninochavez.co" class="text-zinc-400 hover:text-white text-sm transition-colors">ninochavez.co</a>
          </div>
        </div>
      </div>
    </footer>
  </main>
</BaseLayout>
