---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { generateWebsiteSchema, generateBlogSchema, generatePersonSchema } from '../../utils/schema';

export const prerender = true;

// ── Data ────────────────────────────────────────────────────────────────────

const allPosts = await getCollection('blog', ({ data }) => data.status === 'published');
const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);
const featuredEssay = sortedPosts[0];
const recentEssays = sortedPosts.slice(1, 7);
const totalPosts = sortedPosts.length;

// Fiction: find the most recent serial
const fictionAll = await getCollection('fiction', ({ data }) => data.status !== 'draft');
type FictionEntry = typeof fictionAll[number];
const fictionSeriesMap = new Map<string, { title: string; slug: string; chapters: FictionEntry[]; totalChapters?: number; latestDate: number }>();

for (const story of fictionAll) {
  if (story.data.series) {
    const slug = story.data.series.slug;
    if (!fictionSeriesMap.has(slug)) {
      fictionSeriesMap.set(slug, {
        title: story.data.series.title,
        slug,
        chapters: [],
        totalChapters: story.data.series.totalChapters,
        latestDate: 0,
      });
    }
    const s = fictionSeriesMap.get(slug)!;
    s.chapters.push(story);
    const d = new Date(story.data.publishedAt).getTime();
    if (d > s.latestDate) s.latestDate = d;
  }
}

for (const [, s] of fictionSeriesMap) {
  s.chapters.sort(
    (a, b) => (a.data.series?.position || 0) - (b.data.series?.position || 0)
  );
}

const activeFictionSerial = Array.from(fictionSeriesMap.values())
  .sort((a, b) => b.latestDate - a.latestDate)[0];

// Essay series
const seriesAll = await getCollection('series');
const activeSeries = seriesAll
  .filter((s) => s.data.status !== 'completed')
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
  .slice(0, 3);

// Latest from each other content type
async function latestFrom<T extends 'whitepapers' | 'tutorials' | 'presentations' | 'counterpoints'>(
  collection: T
) {
  const items = await getCollection(collection);
  const sorted = items.sort(
    (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
  );
  return sorted[0];
}

const latestWhitepaper = await latestFrom('whitepapers');
const latestTutorial = await latestFrom('tutorials');
const latestPresentation = await latestFrom('presentations');
const latestCounterpoint = await latestFrom('counterpoints');

// ── Helpers ─────────────────────────────────────────────────────────────────

function formatDate(d: string | Date) {
  return new Date(d).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const categoryColors: Record<string, { bg: string; border: string; text: string }> = {
  'AI & Automation': { bg: 'bg-purple-500/10', border: 'border-purple-500/30', text: 'text-purple-400' },
  'Commerce': { bg: 'bg-orange-500/10', border: 'border-orange-500/30', text: 'text-orange-400' },
  'Leadership': { bg: 'bg-blue-500/10', border: 'border-blue-500/30', text: 'text-blue-400' },
  'Meta': { bg: 'bg-zinc-500/10', border: 'border-zinc-500/30', text: 'text-zinc-400' },
  'Field Notes': { bg: 'bg-green-500/10', border: 'border-green-500/30', text: 'text-green-400' },
  'Consulting Practice': { bg: 'bg-cyan-500/10', border: 'border-cyan-500/30', text: 'text-cyan-400' },
  default: { bg: 'bg-athletic-brand-violet/10', border: 'border-athletic-brand-violet/30', text: 'text-athletic-brand-violet' },
};

function catColors(category?: string) {
  return categoryColors[category || ''] || categoryColors.default;
}

// JSON-LD
const websiteSchema = generateWebsiteSchema();
const blogSchema = generateBlogSchema(sortedPosts);
const personSchema = generatePersonSchema();
---

<BaseLayout
  title="Signal Dispatch"
  description="Architecture, commerce, and the signals that matter. Essays, fiction, whitepapers, and research."
  jsonLd={[websiteSchema, blogSchema, personSchema]}
>
  <main class="min-h-screen">
    <SiteHeader currentPage="blog" />

    <!-- Hero (compact) -->
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-8 md:pt-16 md:pb-10 text-center border-b border-zinc-800/50">
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl text-white leading-[1.05] tracking-tight mb-3">
        Signal Dispatch
      </h1>
      <p class="font-serif italic text-base md:text-lg text-zinc-500">
        Architecture, commerce, and the signals that matter.
      </p>
    </section>

    <!-- Main content: essay column + sidebar -->
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-14">
      <div class="grid gap-10 md:gap-12 md:grid-cols-3">

        <!-- ── Main column (2/3) ── -->
        <div class="md:col-span-2 space-y-12">

          <!-- Featured essay -->
          {featuredEssay && (
            <section>
              <h2 class="text-xs uppercase tracking-[0.25em] text-zinc-500 mb-5 pb-3 border-b border-zinc-800/60">
                Featured
              </h2>
              <a href={`/blog/${featuredEssay.id}`} class="group block">
                <article class="space-y-4">
                  {featuredEssay.data.featureImage && (
                    <div class="relative aspect-[16/9] overflow-hidden rounded-lg border border-zinc-800/60">
                      <img
                        src={featuredEssay.data.featureImage}
                        alt={featuredEssay.data.title}
                        class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
                        loading="eager"
                        decoding="async"
                      />
                    </div>
                  )}
                  <div class="space-y-2">
                    <div class="flex items-center gap-3 text-xs flex-wrap">
                      {featuredEssay.data.category && (() => {
                        const colors = catColors(featuredEssay.data.category);
                        return (
                          <span class={`font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full border ${colors.bg} ${colors.border} ${colors.text}`}>
                            {featuredEssay.data.category}
                          </span>
                        );
                      })()}
                      <time class="text-zinc-600">
                        {formatDate(featuredEssay.data.publishedAt)}
                      </time>
                    </div>
                    <h3 class="font-bold text-2xl md:text-3xl text-white group-hover:text-athletic-court-orange transition-colors leading-tight">
                      {featuredEssay.data.title}
                    </h3>
                    {featuredEssay.data.excerpt && (
                      <p class="text-zinc-400 leading-relaxed line-clamp-2">
                        {featuredEssay.data.excerpt}
                      </p>
                    )}
                  </div>
                </article>
              </a>
            </section>
          )}

          <!-- Latest essays grid -->
          <section>
            <div class="flex items-baseline justify-between mb-5 pb-3 border-b border-zinc-800/60">
              <h2 class="text-xs uppercase tracking-[0.25em] text-zinc-500">
                Latest Essays
              </h2>
              <a
                href="/blog/archive"
                class="text-xs text-zinc-600 hover:text-athletic-court-orange transition-colors"
              >
                All {totalPosts} →
              </a>
            </div>

            <div class="grid gap-6 sm:grid-cols-2">
              {recentEssays.map((post) => {
                const colors = catColors(post.data.category);
                return (
                  <a href={`/blog/${post.id}`} class="group block">
                    <article class="space-y-3">
                      {post.data.featureImage && (
                        <div class="relative aspect-video overflow-hidden rounded-lg border border-zinc-800/60">
                          <img
                            src={post.data.featureImage}
                            alt={post.data.title}
                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                            loading="lazy"
                            decoding="async"
                          />
                        </div>
                      )}
                      <div class="space-y-1.5">
                        <div class="flex items-center gap-2 text-xs">
                          {post.data.category && (
                            <span class={`font-semibold uppercase tracking-wider px-2 py-0.5 rounded-full border ${colors.bg} ${colors.border} ${colors.text}`}>
                              {post.data.category}
                            </span>
                          )}
                        </div>
                        <h3 class="font-bold text-base text-white group-hover:text-athletic-court-orange transition-colors leading-tight">
                          {post.data.title}
                        </h3>
                      </div>
                    </article>
                  </a>
                );
              })}
            </div>

            <div class="mt-8 text-center md:text-left">
              <a
                href="/blog/archive"
                class="inline-flex items-center gap-2 text-sm text-zinc-400 hover:text-athletic-court-orange transition-colors"
              >
                See all {totalPosts} essays
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </a>
            </div>
          </section>

        </div>

        <!-- ── Sidebar (1/3) ── -->
        <aside class="md:col-span-1 space-y-10">

          <!-- Currently Serializing -->
          {activeFictionSerial && (
            <section>
              <h2 class="text-xs uppercase tracking-[0.25em] text-zinc-500 mb-5 pb-3 border-b border-zinc-800/60">
                Currently Serializing
              </h2>
              <a href={`/blog/fiction/${activeFictionSerial.chapters[0].id}`} class="group block">
                <div class="text-xs uppercase tracking-wider text-zinc-600 mb-2">
                  Novella &middot; {activeFictionSerial.chapters.length} of {activeFictionSerial.totalChapters || activeFictionSerial.chapters.length} chapters
                </div>
                <h3 class="font-serif text-2xl text-white group-hover:text-athletic-court-orange transition-colors leading-tight mb-3">
                  {activeFictionSerial.title}
                </h3>
                {activeFictionSerial.chapters[0].data.excerpt && (
                  <p class="font-serif italic text-sm text-zinc-500 leading-relaxed line-clamp-3 mb-4">
                    {activeFictionSerial.chapters[0].data.excerpt}
                  </p>
                )}
                <span class="inline-flex items-center gap-1.5 text-xs font-medium text-athletic-court-orange group-hover:text-white transition-colors">
                  Start from the beginning
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                  </svg>
                </span>
              </a>
            </section>
          )}

          <!-- Essay Series -->
          {activeSeries.length > 0 && (
            <section>
              <div class="flex items-baseline justify-between mb-5 pb-3 border-b border-zinc-800/60">
                <h2 class="text-xs uppercase tracking-[0.25em] text-zinc-500">
                  Essay Series
                </h2>
                <a
                  href="/blog/series"
                  class="text-xs text-zinc-600 hover:text-athletic-court-orange transition-colors"
                >
                  All →
                </a>
              </div>
              <ul class="space-y-3">
                {activeSeries.map((series) => (
                  <li>
                    <a
                      href={`/blog/series/${series.id}`}
                      class="group block"
                    >
                      <h3 class="text-sm font-semibold text-zinc-300 group-hover:text-athletic-court-orange transition-colors leading-snug">
                        {series.data.title}
                      </h3>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}

          <!-- Also Here -->
          <section>
            <h2 class="text-xs uppercase tracking-[0.25em] text-zinc-500 mb-5 pb-3 border-b border-zinc-800/60">
              Also Here
            </h2>
            <ul class="space-y-4 text-sm">
              {latestWhitepaper && (
                <li>
                  <a href="/blog/whitepapers" class="group block">
                    <div class="text-xs uppercase tracking-wider text-zinc-600 mb-0.5">Whitepapers</div>
                    <div class="text-zinc-400 group-hover:text-athletic-court-orange transition-colors line-clamp-1">
                      Latest: {latestWhitepaper.data.title}
                    </div>
                  </a>
                </li>
              )}
              {latestTutorial && (
                <li>
                  <a href="/blog/tutorials" class="group block">
                    <div class="text-xs uppercase tracking-wider text-zinc-600 mb-0.5">Tutorials</div>
                    <div class="text-zinc-400 group-hover:text-athletic-court-orange transition-colors line-clamp-1">
                      Latest: {latestTutorial.data.title}
                    </div>
                  </a>
                </li>
              )}
              {latestPresentation && (
                <li>
                  <a href="/blog/presentations" class="group block">
                    <div class="text-xs uppercase tracking-wider text-zinc-600 mb-0.5">Presentations</div>
                    <div class="text-zinc-400 group-hover:text-athletic-court-orange transition-colors line-clamp-1">
                      Latest: {latestPresentation.data.title}
                    </div>
                  </a>
                </li>
              )}
              {latestCounterpoint && (
                <li>
                  <a href="/blog/counterpoints" class="group block">
                    <div class="text-xs uppercase tracking-wider text-zinc-600 mb-0.5">Counterpoints</div>
                    <div class="text-zinc-400 group-hover:text-athletic-court-orange transition-colors line-clamp-1">
                      Latest: {latestCounterpoint.data.title}
                    </div>
                  </a>
                </li>
              )}
              <li>
                <a href="/research" class="group block">
                  <div class="text-xs uppercase tracking-wider text-zinc-600 mb-0.5">Research Notes</div>
                  <div class="text-zinc-400 group-hover:text-athletic-court-orange transition-colors line-clamp-1">
                    Working documents and methodology
                  </div>
                </a>
              </li>
            </ul>
          </section>

        </aside>
      </div>
    </div>

    <SiteFooter />
  </main>
</BaseLayout>
