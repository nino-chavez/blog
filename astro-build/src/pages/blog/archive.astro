---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogList from '../../components/BlogList';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { generateWebsiteSchema, generateBlogSchema, generatePersonSchema } from '../../utils/schema';

export const prerender = true;

// Get all published posts sorted by date
const posts = await getCollection('blog', ({ data }) => data.status === 'published');
const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);

// Prepare posts data for BlogList component
const postsData = sortedPosts.map((post) => ({
  id: post.id,
  title: post.data.title,
  excerpt: post.data.excerpt || '',
  publishedAt: typeof post.data.publishedAt === 'string'
    ? post.data.publishedAt
    : post.data.publishedAt.toISOString(),
  category: post.data.category,
  tags: post.data.tags,
  featured: post.data.featured,
  featureImage: post.data.featureImage,
}));

// Generate JSON-LD schemas
const websiteSchema = generateWebsiteSchema();
const blogSchema = generateBlogSchema(sortedPosts);
const personSchema = generatePersonSchema();
---

<BaseLayout
  title="Essays — Signal Dispatch"
  description="All essays. Architecture, commerce, and the signals that matter."
  jsonLd={[websiteSchema, blogSchema, personSchema]}
>
  <main class="min-h-screen">
    <SiteHeader currentPage="blog" />

    <!-- Page Header -->
    <section class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 pt-8 sm:pt-12 pb-2">
      <div class="max-w-3xl">
        <a
          href="/blog"
          class="group inline-flex items-center gap-2 text-sm text-zinc-500 hover:text-athletic-court-orange transition-colors mb-4 no-print"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Signal Dispatch home
        </a>
        <h1 class="font-serif text-4xl md:text-5xl text-white leading-tight tracking-tight mb-3">
          Essays
        </h1>
        <p class="font-serif italic text-lg text-zinc-500">
          All {sortedPosts.length} posts, filterable by category and searchable by text.
        </p>
      </div>
    </section>

    <!-- Blog Content -->
    <section class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-6 sm:py-8">
      <BlogList posts={postsData} client:idle />
    </section>

    <SiteFooter />
  </main>
</BaseLayout>
