---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import { generateCollectionSchema } from '../../../utils/schema';

export const prerender = true;

// Get all counterpoints sorted by date
const counterpoints = await getCollection('counterpoints');
const sortedCounterpoints = counterpoints.sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);

// Get blog posts for cross-referencing challenged posts
const posts = await getCollection('blog');

// Generate JSON-LD
const collectionSchema = generateCollectionSchema(
  'Signal Dispatch Counterpoints',
  'Adversarial challenges to Signal Dispatch posts. Stress-testing ideas through structured critique.',
  'https://ninochavez.co/blog/counterpoints',
  sortedCounterpoints
);

// Default images for counterpoints without feature images
const getCounterpointImage = (cp: typeof sortedCounterpoints[0]) => {
  if (cp.data.featureImage) return cp.data.featureImage;
  const hash = cp.id.split('').reduce((acc, char) => acc + char.charCodeAt(0), 0);
  const variant = (hash % 5) + 1;
  return `/generated/categories/ai-automation-${variant}.webp`;
};

// Challenge source type labels
const sourceTypeLabels: Record<string, string> = {
  'ai-analysis': 'AI Analysis',
  'external-contributor': 'External Contributor',
  'self-critique': 'Self-Critique',
};
---

<BaseLayout
  title="Counterpoints"
  description="Adversarial challenges to Signal Dispatch posts. Stress-testing ideas through structured critique."
  jsonLd={[collectionSchema]}
>
  <main class="min-h-screen">
    <SiteHeader currentPage="counterpoints" />

    <!-- Compact Page Header -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
        <div class="space-y-3">
          <a href="/blog" class="group inline-flex items-center gap-2 text-sm text-zinc-500 hover:text-athletic-court-orange transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Blog
          </a>
          <div class="flex items-center gap-4">
            <h1 class="text-3xl md:text-4xl font-black text-white">Counterpoints</h1>
            <span class="text-sm text-zinc-500 bg-zinc-900/50 px-3 py-1 rounded-full border border-zinc-800">
              {sortedCounterpoints.length} {sortedCounterpoints.length === 1 ? 'challenge' : 'challenges'}
            </span>
          </div>
          <p class="text-zinc-400 max-w-2xl">
            Adversarial challenges to Signal Dispatch posts. Stress-testing ideas through structured critique.
          </p>
        </div>

        <!-- AI-assisted note -->
        <div class="flex items-center gap-2 text-xs text-zinc-500 bg-zinc-900/30 px-3 py-2 rounded-lg border border-zinc-800/50 lg:self-end">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-teal-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
          </svg>
          <span>Adversarial analysis for intellectual rigor</span>
        </div>
      </div>
    </section>

    <!-- Counterpoints Grid -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
      <div class="grid gap-6">
        {sortedCounterpoints.map((cp, index) => {
          const wordCount = cp.body?.split(/\s+/).length || 0;
          const readingTime = Math.ceil(wordCount / 200);
          const isNew = (new Date().getTime() - new Date(cp.data.publishedAt).getTime()) / (1000 * 60 * 60 * 24) <= 14;
          const imageUrl = getCounterpointImage(cp);
          const originalPost = posts.find((p) => p.id === cp.data.challengesPost.slug);

          return (
            <a href={`/blog/counterpoints/${cp.id}`} class="group block">
              <article class={`relative overflow-hidden rounded-2xl border transition-all duration-300 hover:shadow-xl hover:shadow-teal-600/10 ${index === 0 ? 'border-teal-600/40 bg-gradient-to-br from-zinc-900/80 via-zinc-900/50 to-zinc-950' : 'border-zinc-800 bg-zinc-900/30 hover:border-teal-600/50'}`}>
                <div class="flex flex-col md:flex-row">
                  {/* Image */}
                  <div class="md:w-2/5 lg:w-1/3 relative">
                    <div class="aspect-[16/9] md:aspect-auto md:absolute md:inset-0 overflow-hidden">
                      <img
                        src={imageUrl}
                        alt={cp.data.title}
                        width="800"
                        height="450"
                        class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                        loading={index === 0 ? "eager" : "lazy"}
                        fetchpriority={index === 0 ? "high" : "auto"}
                        decoding="async"
                      />
                      <div class="absolute inset-0 bg-gradient-to-r from-transparent via-transparent to-zinc-900/90 hidden md:block" />
                      <div class="absolute inset-0 bg-gradient-to-t from-zinc-900 via-transparent to-transparent md:hidden" />
                    </div>
                    {/* Badges on image */}
                    <div class="absolute top-4 left-4 flex items-center gap-2">
                      {isNew && (
                        <span class="font-bold uppercase tracking-wider px-2.5 py-1 rounded-full bg-gradient-to-r from-teal-600 to-cyan-500 text-white text-[10px] shadow-lg">
                          New
                        </span>
                      )}
                      {index === 0 && (
                        <span class="font-bold uppercase tracking-wider px-2.5 py-1 rounded-full bg-teal-600/90 text-white text-[10px] shadow-lg backdrop-blur-sm">
                          Latest
                        </span>
                      )}
                    </div>
                  </div>

                  {/* Content */}
                  <div class="flex-1 p-6 md:p-8 flex flex-col justify-center">
                    <div class="flex items-center gap-3 text-xs mb-3 flex-wrap">
                      <span class="font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full bg-teal-600/10 border border-teal-600/30 text-teal-400">
                        Counterpoint
                      </span>
                      <span class="text-zinc-600">&bull;</span>
                      <span class="text-zinc-500">{cp.data.challengeSource.name}</span>
                      <span class="text-zinc-600">&bull;</span>
                      <span class="text-zinc-500">
                        {new Date(cp.data.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                      </span>
                      <span class="text-zinc-600">&bull;</span>
                      <span class="flex items-center gap-1 text-zinc-500">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        {readingTime} min
                      </span>
                    </div>

                    <h2 class={`font-bold text-white group-hover:text-athletic-court-orange transition-colors mb-3 ${index === 0 ? 'text-2xl md:text-3xl' : 'text-xl md:text-2xl'}`}>
                      {cp.data.title}
                    </h2>

                    {originalPost && (
                      <p class="text-sm text-teal-400/80 mb-2">
                        Challenges: {originalPost.data.title}
                      </p>
                    )}

                    {cp.data.excerpt && (
                      <p class={`text-zinc-400 leading-relaxed mb-4 ${index === 0 ? 'line-clamp-3' : 'line-clamp-2'}`}>
                        {cp.data.excerpt}
                      </p>
                    )}

                    <div class="inline-flex items-center gap-2 text-teal-400 group-hover:text-athletic-court-orange transition-colors font-semibold text-sm">
                      <span>Read counterpoint</span>
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                      </svg>
                    </div>
                  </div>
                </div>
              </article>
            </a>
          );
        })}
      </div>
    </section>

    <SiteFooter />
  </main>
</BaseLayout>
