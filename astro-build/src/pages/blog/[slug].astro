---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { generateArticleSchema, generateBreadcrumbSchema } from '../../utils/schema';
import ReadingProgress from '../../components/ReadingProgress';
import SeriesNav from '../../components/SeriesNav.astro';

// In SSR mode, get the post from the slug parameter
const { slug } = Astro.params;
const posts = await getCollection('blog');
const post = posts.find((p) => p.id === slug && p.data.status !== 'draft');

if (!post) {
  return Astro.redirect('/blog');
}

const { Content } = await render(post);

// Generate JSON-LD schemas
const articleSchema = generateArticleSchema(post);
const breadcrumbSchema = generateBreadcrumbSchema(post);

// Format dates
const publishedDate = new Date(post.data.publishedAt);
const formattedDate = publishedDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Calculate reading time (rough estimate: 200 words per minute)
const wordCount = post.body?.split(/\s+/).length || 0;
const readingTime = Math.ceil(wordCount / 200);

// Category colors
const categoryColors: Record<string, { bg: string; border: string; text: string }> = {
  'AI & Automation': { bg: 'bg-purple-500/10', border: 'border-purple-500/30', text: 'text-purple-400' },
  'Commerce': { bg: 'bg-orange-500/10', border: 'border-orange-500/30', text: 'text-orange-400' },
  'Leadership': { bg: 'bg-blue-500/10', border: 'border-blue-500/30', text: 'text-blue-400' },
  'Meta': { bg: 'bg-zinc-500/10', border: 'border-zinc-500/30', text: 'text-zinc-400' },
  'Field Notes': { bg: 'bg-green-500/10', border: 'border-green-500/30', text: 'text-green-400' },
  'Consulting Practice': { bg: 'bg-cyan-500/10', border: 'border-cyan-500/30', text: 'text-cyan-400' },
  'default': { bg: 'bg-athletic-brand-violet/10', border: 'border-athletic-brand-violet/30', text: 'text-athletic-brand-violet' },
};

const colors = categoryColors[post.data.category || ''] || categoryColors.default;

// Get related posts (same category, excluding current)
const allPosts = await getCollection('blog', ({ data }) => data.status !== 'draft');
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id && p.data.category === post.data.category)
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
  .slice(0, 3);
---

<BaseLayout
  title={post.data.title}
  description={post.data.excerpt}
  image={post.data.featureImage}
  type="article"
  publishedTime={publishedDate.toISOString()}
  modifiedTime={post.data.updatedAt ? new Date(post.data.updatedAt).toISOString() : undefined}
  author={post.data.author}
  tags={post.data.tags}
  jsonLd={[articleSchema, breadcrumbSchema]}
>
  <!-- Reading Progress Bar -->
  <ReadingProgress client:load />

  <main class="min-h-screen">
    <!-- Header Navigation -->
    <header class="sticky top-0 z-50 bg-zinc-950/80 backdrop-blur-lg border-b border-zinc-800/50 no-print">
      <nav class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/blog" class="flex items-center gap-2 text-white hover:text-athletic-court-orange transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          <span class="font-semibold">Signal Dispatch</span>
        </a>
        <div class="flex items-center gap-4">
          <a href="/rss.xml" class="text-zinc-400 hover:text-white transition-colors" title="RSS Feed">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7m-6 0a1 1 0 11-2 0 1 1 0 012 0z" />
            </svg>
          </a>
        </div>
      </nav>
    </header>

    <div class="max-w-3xl mx-auto px-4 py-12">
      <!-- Back link -->
      <a
        href="/blog"
        class="group inline-flex items-center gap-2 text-zinc-400 hover:text-athletic-court-orange transition-all duration-150 font-medium mb-8 no-print"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to all posts
      </a>

      <article class="space-y-6">
        <!-- Featured Image -->
        {post.data.featureImage && (
          <div class="relative -mx-4 md:-mx-8 lg:mx-0 aspect-video overflow-hidden rounded-2xl border border-zinc-800">
            <img
              src={post.data.featureImage}
              alt={post.data.title}
              class="w-full h-full object-cover"
              loading="eager"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-transparent to-transparent opacity-60"></div>
          </div>
        )}

        <!-- Article Header -->
        <header class="space-y-3 pb-6 border-b border-zinc-800/50">
          <div class="flex items-center gap-3 text-sm flex-wrap">
            {post.data.category && (
              <span class={`font-bold uppercase tracking-wider px-3 py-1.5 rounded-full border transition-colors ${colors.bg} ${colors.border} ${colors.text}`}>
                {post.data.category}
              </span>
            )}
            {post.data.category && <span class="text-zinc-700">•</span>}
            <time datetime={publishedDate.toISOString()} class="text-zinc-500">
              {formattedDate}
            </time>
            <span class="text-zinc-700">•</span>
            <span class="flex items-center gap-1.5 text-zinc-500">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {readingTime} min read
            </span>
          </div>

          <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white leading-tight tracking-tight">
            {post.data.title}
          </h1>

          {post.data.excerpt && (
            <p class="excerpt text-xl text-zinc-400 leading-relaxed">
              {post.data.excerpt}
            </p>
          )}

          {post.data.tags && post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 pt-4">
              {post.data.tags.map((tag) => (
                <span class="text-xs px-3 py-1.5 rounded-full bg-zinc-900/50 text-zinc-400 border border-zinc-800 hover:border-athletic-brand-violet/50 hover:text-athletic-brand-violet transition-all duration-150 cursor-default">
                  {tag}
                </span>
              ))}
            </div>
          )}

          <!-- Author Info -->
          <div class="flex items-center gap-4 pt-6 mt-2 border-t border-zinc-800/30">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-athletic-brand-violet to-athletic-court-orange flex items-center justify-center text-white font-bold text-lg shadow-lg shadow-athletic-brand-violet/20">
              NC
            </div>
            <div>
              <p class="text-white font-semibold">{post.data.author || 'Nino Chavez'}</p>
              <p class="text-zinc-500 text-sm">Principal Consultant & Enterprise Architect</p>
            </div>
          </div>
        </header>

        <!-- Series Navigation (if post is part of a series) -->
        {post.data.series && (
          <SeriesNav
            seriesSlug={post.data.series.slug}
            currentPosition={post.data.series.position}
          />
        )}

        <!-- Article Content -->
        <div class="prose max-w-none text-lg">
          <Content />
        </div>

        <!-- Social Sharing -->
        <div class="pt-8 pb-8 border-t border-zinc-800/50 no-print">
          <div class="flex items-center gap-4">
            <span class="text-zinc-500 text-sm font-medium">Share:</span>
            <a
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(`https://ninochavez.co/blog/${post.id}`)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-zinc-400 hover:text-white transition-colors"
              title="Share on Twitter"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`https://ninochavez.co/blog/${post.id}`)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-zinc-400 hover:text-[#0A66C2] transition-colors"
              title="Share on LinkedIn"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
            <button
              onclick={`navigator.clipboard.writeText('https://ninochavez.co/blog/${post.id}'); this.textContent = 'Copied!'`}
              class="text-zinc-400 hover:text-athletic-brand-violet transition-colors text-sm"
              title="Copy link"
            >
              Copy link
            </button>
          </div>
        </div>

        <!-- LinkedIn Attribution (if applicable) -->
        {post.data.source === 'linkedin' && post.data.linkedinUrl && (
          <div class="mt-8 p-6 rounded-xl border border-[#0A66C2]/20 bg-[#0A66C2]/5 no-print">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 mt-1">
                <svg class="w-6 h-6 text-[#0A66C2]" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </div>
              <div class="flex-1">
                <h3 class="text-sm font-semibold text-[#0A66C2] mb-1">
                  Originally Published on LinkedIn
                </h3>
                <p class="text-sm text-zinc-400 mb-3">
                  This article was first published on my LinkedIn profile. Click below to view the original post and join the conversation.
                </p>
                <a
                  href={post.data.linkedinUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-[#0A66C2] text-white text-sm font-medium hover:bg-[#004182] transition-colors"
                >
                  View on LinkedIn
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              </div>
            </div>
          </div>
        )}
      </article>

      <!-- Related Posts -->
      {relatedPosts.length > 0 && (
        <section class="mt-16 pt-12 border-t border-zinc-800/50 no-print">
          <h2 class="text-2xl font-bold text-white mb-8">More in {post.data.category}</h2>
          <div class="grid gap-6 md:grid-cols-3">
            {relatedPosts.map((related) => (
              <a href={`/blog/${related.id}`} class="group block">
                <article class="h-full p-5 rounded-xl border border-zinc-800 hover:border-athletic-brand-violet/50 transition-all duration-200 bg-zinc-900/30 hover:bg-zinc-900/50 hover:shadow-lg hover:shadow-athletic-brand-violet/5 hover:-translate-y-1">
                  <div class="space-y-3">
                    <time class="text-xs text-zinc-500">
                      {new Date(related.data.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </time>
                    <h3 class="text-base font-bold text-white group-hover:text-athletic-court-orange transition-colors line-clamp-2">
                      {related.data.title}
                    </h3>
                    {related.data.excerpt && (
                      <p class="text-zinc-400 text-sm leading-relaxed line-clamp-2">
                        {related.data.excerpt}
                      </p>
                    )}
                  </div>
                </article>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>

    <!-- Footer -->
    <footer class="border-t border-zinc-800/50 py-12 mt-12 no-print">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <p class="text-zinc-500 text-sm">
          &copy; {new Date().getFullYear()} Nino Chavez. All rights reserved.
        </p>
        <div class="flex justify-center gap-4 mt-4">
          <a href="/rss.xml" class="text-zinc-400 hover:text-white text-sm transition-colors">RSS</a>
          <span class="text-zinc-700">•</span>
          <a href="/api/posts.json" class="text-zinc-400 hover:text-white text-sm transition-colors">API</a>
          <span class="text-zinc-700">•</span>
          <a href="https://ninochavez.co" class="text-zinc-400 hover:text-white text-sm transition-colors">ninochavez.co</a>
        </div>
      </div>
    </footer>
  </main>
</BaseLayout>
