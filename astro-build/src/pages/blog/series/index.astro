---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import { generateCollectionSchema } from '../../../utils/schema';

export const prerender = true;

// Get all series sorted by date
const allSeries = await getCollection('series');
const sortedSeries = allSeries.sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);

// Get all blog posts to count posts per series
const blogPosts = await getCollection('blog', ({ data }) => data.status !== 'draft');

// Count posts per series
const getPostCount = (seriesSlug: string) => {
  return blogPosts.filter(post => post.data.series?.slug === seriesSlug).length;
};

// Generate JSON-LD
const collectionSchema = generateCollectionSchema(
  'Signal Dispatch Series',
  'Curated multi-part explorations on AI, commerce, and systems thinking.',
  'https://ninochavez.co/blog/series',
  sortedSeries.map(s => ({
    id: s.id,
    data: {
      title: s.data.title,
      excerpt: s.data.description,
      publishedAt: s.data.publishedAt,
      author: 'Nino Chavez',
    }
  }))
);
---

<BaseLayout
  title="Series"
  description="Curated multi-part explorations on AI, commerce, leadership, and systems thinking by Nino Chavez."
  jsonLd={[collectionSchema]}
>
  <main class="min-h-screen">
    <SiteHeader currentPage="series" />

    <!-- Compact Page Header -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
        <div class="space-y-3">
          <a href="/blog" class="group inline-flex items-center gap-2 text-sm text-zinc-500 hover:text-athletic-court-orange transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Blog
          </a>
          <div class="flex items-center gap-4">
            <h1 class="text-3xl md:text-4xl font-black text-white">Series</h1>
            <span class="text-sm text-zinc-500 bg-zinc-900/50 px-3 py-1 rounded-full border border-zinc-800">
              {sortedSeries.length} collections
            </span>
          </div>
          <p class="text-zinc-400 max-w-2xl">
            Multi-part explorations. Each series builds a complete arc—from opening tension to synthesis.
          </p>
        </div>
      </div>
    </section>

    <!-- Series Grid -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
      <div class="grid gap-6">
        {sortedSeries.map((series, index) => {
          const postCount = getPostCount(series.id);
          const isCompleted = series.data.status === 'completed';

          return (
            <a href={`/blog/series/${series.id}`} class="group block">
              <article class={`relative overflow-hidden rounded-2xl border transition-all duration-300 hover:shadow-xl hover:shadow-athletic-brand-violet/10 ${index === 0 ? 'border-athletic-brand-violet/40 bg-gradient-to-br from-zinc-900/80 via-zinc-900/50 to-zinc-950' : 'border-zinc-800 bg-zinc-900/30 hover:border-athletic-brand-violet/50'}`}>
                <div class="p-6 md:p-8">
                  <div class="flex items-center gap-3 text-xs mb-4 flex-wrap">
                    <span class="font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full bg-athletic-court-orange/10 border border-athletic-court-orange/30 text-athletic-court-orange">
                      Series
                    </span>
                    <span class="text-zinc-500">
                      {postCount} {postCount === 1 ? 'post' : 'posts'}
                    </span>
                    {isCompleted && (
                      <span class="font-medium px-2.5 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 text-[10px] uppercase tracking-wider">
                        Complete
                      </span>
                    )}
                    {index === 0 && (
                      <span class="font-bold uppercase tracking-wider px-2.5 py-1 rounded-full bg-athletic-brand-violet/90 text-white text-[10px] shadow-lg backdrop-blur-sm">
                        Latest
                      </span>
                    )}
                  </div>

                  <h2 class={`font-bold text-white group-hover:text-athletic-court-orange transition-colors mb-3 ${index === 0 ? 'text-2xl md:text-3xl' : 'text-xl md:text-2xl'}`}>
                    {series.data.title}
                  </h2>

                  <p class={`text-zinc-400 leading-relaxed mb-4 ${index === 0 ? 'line-clamp-3' : 'line-clamp-2'}`}>
                    {series.data.description}
                  </p>

                  <div class="flex items-center justify-between">
                    <div class="inline-flex items-center gap-2 text-athletic-brand-violet group-hover:text-athletic-court-orange transition-colors font-semibold text-sm">
                      <span>Explore series</span>
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                      </svg>
                    </div>

                    {series.data.tags && series.data.tags.length > 0 && (
                      <div class="hidden sm:flex items-center gap-2">
                        {series.data.tags.slice(0, 2).map(tag => (
                          <span class="text-xs text-zinc-500 bg-zinc-800/50 px-2 py-1 rounded">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              </article>
            </a>
          );
        })}
      </div>
    </section>

    <SiteFooter />
  </main>
</BaseLayout>
