---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { generateCollectionSchema } from '../../../utils/schema';

// Get all series sorted by date
const allSeries = await getCollection('series');
const sortedSeries = allSeries.sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);

// Get all blog posts to count posts per series
const blogPosts = await getCollection('blog', ({ data }) => data.status !== 'draft');

// Count posts per series
const getPostCount = (seriesSlug: string) => {
  return blogPosts.filter(post => post.data.series?.slug === seriesSlug).length;
};

// Generate JSON-LD
const collectionSchema = generateCollectionSchema(
  'Signal Dispatch Series',
  'Curated multi-part explorations on AI, commerce, and systems thinking.',
  'https://blog.ninochavez.co/series',
  sortedSeries.map(s => ({
    id: s.id,
    data: {
      title: s.data.title,
      excerpt: s.data.description,
      publishedAt: s.data.publishedAt,
      author: 'Nino Chavez',
    }
  }))
);
---

<BaseLayout
  title="Series"
  description="Curated multi-part explorations on AI, commerce, leadership, and systems thinking by Nino Chavez."
  jsonLd={[collectionSchema]}
>
  <main class="min-h-screen">
    <!-- Compact Header -->
    <header class="sticky top-0 z-50 bg-zinc-950/95 backdrop-blur-xl border-b border-zinc-800/30">
      <nav class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-[56px] sm:h-[73px]">
          <a href="/blog" class="flex items-center gap-2 sm:gap-3 flex-shrink min-w-0">
            <h1 class="text-sm xs:text-base sm:text-lg font-bold bg-gradient-to-r from-athletic-brand-violet to-athletic-court-orange bg-clip-text text-transparent truncate">
              Signal Dispatch
            </h1>
          </a>
          <div class="flex items-center gap-1 sm:gap-4 flex-shrink-0">
            <a href="/blog" class="hidden sm:block text-sm text-zinc-400 hover:text-white transition-colors">Blog</a>
            <a href="/blog/whitepapers" class="hidden sm:block text-sm text-zinc-400 hover:text-white transition-colors">Whitepapers</a>
            <a href="/blog/presentations" class="hidden sm:block text-sm text-zinc-400 hover:text-white transition-colors">Presentations</a>
            <!-- Mobile icons -->
            <a href="/blog" class="sm:hidden flex items-center justify-center w-9 h-9 rounded-lg text-zinc-400 hover:text-white hover:bg-zinc-800/50 transition-colors" title="Blog">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
              </svg>
            </a>
            <a href="/blog/whitepapers" class="sm:hidden flex items-center justify-center w-9 h-9 rounded-lg text-zinc-400 hover:text-white hover:bg-zinc-800/50 transition-colors" title="Whitepapers">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </a>
            <a href="/blog/presentations" class="sm:hidden flex items-center justify-center w-9 h-9 rounded-lg text-zinc-400 hover:text-white hover:bg-zinc-800/50 transition-colors" title="Presentations">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z" />
              </svg>
            </a>
            <a href="/rss.xml" class="flex items-center justify-center w-9 h-9 sm:w-auto sm:h-auto rounded-lg text-zinc-400 hover:text-white hover:bg-zinc-800/50 sm:hover:bg-transparent transition-colors" title="RSS Feed">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7m-6 0a1 1 0 11-2 0 1 1 0 012 0z" />
              </svg>
            </a>
          </div>
        </div>
      </nav>
    </header>

    <!-- Compact Page Header -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
        <div class="space-y-3">
          <a href="/blog" class="group inline-flex items-center gap-2 text-sm text-zinc-500 hover:text-athletic-court-orange transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Blog
          </a>
          <div class="flex items-center gap-4">
            <h1 class="text-3xl md:text-4xl font-black text-white">Series</h1>
            <span class="text-sm text-zinc-500 bg-zinc-900/50 px-3 py-1 rounded-full border border-zinc-800">
              {sortedSeries.length} collections
            </span>
          </div>
          <p class="text-zinc-400 max-w-2xl">
            Multi-part explorations. Each series builds a complete arc—from opening tension to synthesis.
          </p>
        </div>
      </div>
    </section>

    <!-- Series Grid -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
      <div class="grid gap-6">
        {sortedSeries.map((series, index) => {
          const postCount = getPostCount(series.id);
          const isCompleted = series.data.status === 'completed';

          return (
            <a href={`/blog/series/${series.id}`} class="group block">
              <article class={`relative overflow-hidden rounded-2xl border transition-all duration-300 hover:shadow-xl hover:shadow-athletic-brand-violet/10 ${index === 0 ? 'border-athletic-brand-violet/40 bg-gradient-to-br from-zinc-900/80 via-zinc-900/50 to-zinc-950' : 'border-zinc-800 bg-zinc-900/30 hover:border-athletic-brand-violet/50'}`}>
                <div class="p-6 md:p-8">
                  <div class="flex items-center gap-3 text-xs mb-4 flex-wrap">
                    <span class="font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full bg-athletic-court-orange/10 border border-athletic-court-orange/30 text-athletic-court-orange">
                      Series
                    </span>
                    <span class="text-zinc-500">
                      {postCount} {postCount === 1 ? 'post' : 'posts'}
                    </span>
                    {isCompleted && (
                      <span class="font-medium px-2.5 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 text-[10px] uppercase tracking-wider">
                        Complete
                      </span>
                    )}
                    {index === 0 && (
                      <span class="font-bold uppercase tracking-wider px-2.5 py-1 rounded-full bg-athletic-brand-violet/90 text-white text-[10px] shadow-lg backdrop-blur-sm">
                        Latest
                      </span>
                    )}
                  </div>

                  <h2 class={`font-bold text-white group-hover:text-athletic-court-orange transition-colors mb-3 ${index === 0 ? 'text-2xl md:text-3xl' : 'text-xl md:text-2xl'}`}>
                    {series.data.title}
                  </h2>

                  <p class={`text-zinc-400 leading-relaxed mb-4 ${index === 0 ? 'line-clamp-3' : 'line-clamp-2'}`}>
                    {series.data.description}
                  </p>

                  <div class="flex items-center justify-between">
                    <div class="inline-flex items-center gap-2 text-athletic-brand-violet group-hover:text-athletic-court-orange transition-colors font-semibold text-sm">
                      <span>Explore series</span>
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                      </svg>
                    </div>

                    {series.data.tags && series.data.tags.length > 0 && (
                      <div class="hidden sm:flex items-center gap-2">
                        {series.data.tags.slice(0, 2).map(tag => (
                          <span class="text-xs text-zinc-500 bg-zinc-800/50 px-2 py-1 rounded">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              </article>
            </a>
          );
        })}
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-zinc-800/50 py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row justify-between items-center gap-6">
          <p class="text-zinc-500 text-sm">
            &copy; {new Date().getFullYear()} Nino Chavez. All rights reserved.
          </p>
          <div class="flex items-center gap-6">
            <a href="/rss.xml" class="text-zinc-400 hover:text-white text-sm transition-colors">RSS Feed</a>
            <a href="/api/posts.json" class="text-zinc-400 hover:text-white text-sm transition-colors">API</a>
            <a href="https://ninochavez.co" class="text-zinc-400 hover:text-white text-sm transition-colors">ninochavez.co</a>
          </div>
        </div>
      </div>
    </footer>
  </main>
</BaseLayout>
