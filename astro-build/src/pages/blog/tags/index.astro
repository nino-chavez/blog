---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { generateCollectionSchema } from '../../../utils/schema';

// Get all published posts
const allPosts = await getCollection('blog', ({ data }) => data.status !== 'draft');

// Extract all unique tags and count posts per tag
const tagCounts = new Map<string, number>();
allPosts.forEach((post) => {
  post.data.tags?.forEach((tag) => {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  });
});

// Sort tags by count (descending), then alphabetically
const sortedTags = Array.from(tagCounts.entries()).sort((a, b) => {
  if (b[1] !== a[1]) return b[1] - a[1]; // By count desc
  return a[0].localeCompare(b[0]); // Then alphabetically
});

const totalTags = sortedTags.length;

// Generate JSON-LD
const collectionSchema = generateCollectionSchema(
  'Signal Dispatch Tags',
  'Browse posts by topic. All tags used across Signal Dispatch.',
  'https://blog.ninochavez.co/blog/tags',
  []
);
---

<BaseLayout
  title="Tags"
  description="Browse Signal Dispatch posts by topic. All tags used across the blog."
  jsonLd={[collectionSchema]}
>
  <main class="min-h-screen">
    <!-- Header -->
    <header class="sticky top-0 z-50 bg-zinc-950/95 backdrop-blur-xl border-b border-zinc-800/30">
      <nav class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-[56px] sm:h-[73px]">
          <a href="/blog" class="flex items-center gap-2 sm:gap-3 flex-shrink min-w-0">
            <h1 class="text-sm xs:text-base sm:text-lg font-bold bg-gradient-to-r from-athletic-brand-violet to-athletic-court-orange bg-clip-text text-transparent truncate">
              Signal Dispatch
            </h1>
          </a>
          <div class="flex items-center gap-1 sm:gap-4 flex-shrink-0">
            <a href="/blog" class="hidden sm:block text-sm text-zinc-400 hover:text-white transition-colors">Blog</a>
            <a href="/blog/series" class="hidden sm:block text-sm text-zinc-400 hover:text-white transition-colors">Series</a>
            <a href="/blog/whitepapers" class="hidden sm:block text-sm text-zinc-400 hover:text-white transition-colors">Whitepapers</a>
            <a href="/blog/presentations" class="hidden sm:block text-sm text-zinc-400 hover:text-white transition-colors">Presentations</a>
            <!-- Mobile icons -->
            <a href="/blog" class="sm:hidden flex items-center justify-center w-9 h-9 rounded-lg text-zinc-400 hover:text-white hover:bg-zinc-800/50 transition-colors" title="Blog">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
              </svg>
            </a>
            <a href="/blog/series" class="sm:hidden flex items-center justify-center w-9 h-9 rounded-lg text-zinc-400 hover:text-white hover:bg-zinc-800/50 transition-colors" title="Series">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
            </a>
            <a href="/rss.xml" class="flex items-center justify-center w-9 h-9 sm:w-auto sm:h-auto rounded-lg text-zinc-400 hover:text-white hover:bg-zinc-800/50 sm:hover:bg-transparent transition-colors" title="RSS Feed">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7m-6 0a1 1 0 11-2 0 1 1 0 012 0z" />
              </svg>
            </a>
          </div>
        </div>
      </nav>
    </header>

    <!-- Page Header -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="space-y-3">
        <a href="/blog" class="group inline-flex items-center gap-2 text-sm text-zinc-500 hover:text-athletic-court-orange transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to Blog
        </a>
        <div class="flex items-center gap-4">
          <h1 class="text-3xl md:text-4xl font-black text-white">Tags</h1>
          <span class="text-sm text-zinc-500 bg-zinc-900/50 px-3 py-1 rounded-full border border-zinc-800">
            {totalTags} topics
          </span>
        </div>
        <p class="text-zinc-400 max-w-2xl">
          Browse posts by topic. Tags are ordered by frequency—the most-used tags appear first.
        </p>
      </div>
    </section>

    <!-- Tags Cloud -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
      <div class="flex flex-wrap gap-3">
        {sortedTags.map(([tag, count]) => {
          // Size based on count
          const isLarge = count >= 10;
          const isMedium = count >= 5 && count < 10;

          return (
            <a
              href={`/blog/tags/${encodeURIComponent(tag)}`}
              class={`group relative inline-flex items-center gap-2 rounded-xl border transition-all duration-200 hover:border-athletic-brand-violet/50 hover:bg-zinc-900/80 ${
                isLarge
                  ? 'px-5 py-3 bg-zinc-900/60 border-athletic-brand-violet/30'
                  : isMedium
                  ? 'px-4 py-2.5 bg-zinc-900/40 border-zinc-700/50'
                  : 'px-3 py-2 bg-zinc-900/30 border-zinc-800/50'
              }`}
            >
              <span class={`font-medium group-hover:text-athletic-brand-violet transition-colors ${
                isLarge ? 'text-white text-base' : isMedium ? 'text-zinc-200 text-sm' : 'text-zinc-300 text-sm'
              }`}>
                {tag}
              </span>
              <span class={`rounded-full bg-zinc-800/80 group-hover:bg-athletic-brand-violet/20 transition-colors ${
                isLarge ? 'px-2.5 py-0.5 text-sm' : 'px-2 py-0.5 text-xs'
              } text-zinc-400 group-hover:text-athletic-brand-violet`}>
                {count}
              </span>
            </a>
          );
        })}
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-zinc-800/50 py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row justify-between items-center gap-6">
          <p class="text-zinc-500 text-sm">
            &copy; {new Date().getFullYear()} Nino Chavez. All rights reserved.
          </p>
          <div class="flex items-center gap-6">
            <a href="/rss.xml" class="text-zinc-400 hover:text-white text-sm transition-colors">RSS Feed</a>
            <a href="/api/posts.json" class="text-zinc-400 hover:text-white text-sm transition-colors">API</a>
            <a href="https://ninochavez.co" class="text-zinc-400 hover:text-white text-sm transition-colors">ninochavez.co</a>
          </div>
        </div>
      </div>
    </footer>
  </main>
</BaseLayout>
