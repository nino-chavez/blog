---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import ReadingProgress from '../../../components/ReadingProgress';

export const prerender = true;

export async function getStaticPaths() {
  const stories = await getCollection('fiction');
  return stories
    .filter((s) => s.data.status !== 'draft')
    .map((story) => ({ params: { slug: story.id } }));
}

const { slug } = Astro.params;
const stories = await getCollection('fiction');
const story = stories.find((s) => s.id === slug && s.data.status !== 'draft');

if (!story) {
  return Astro.redirect('/blog/fiction');
}

const { Content } = await render(story);

const publishedDate = new Date(story.data.publishedAt);
const formattedDate = publishedDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const wordCount = story.body?.split(/\s+/).length || 0;
const readingTime = Math.ceil(wordCount / 200);

const formLabel: Record<string, string> = {
  'flash': 'Flash Fiction',
  'short-story': 'Short Story',
  'novelette': 'Novelette',
  'novella': 'Novella',
};

// Series navigation
let seriesChapters: typeof stories = [];
let prevChapter: typeof stories[number] | null = null;
let nextChapter: typeof stories[number] | null = null;

if (story.data.series) {
  const seriesSlug = story.data.series.slug;
  seriesChapters = stories
    .filter((s) => s.data.status !== 'draft' && s.data.series?.slug === seriesSlug)
    .sort((a, b) => (a.data.series?.position || 0) - (b.data.series?.position || 0));

  const currentIndex = seriesChapters.findIndex((s) => s.id === story.id);
  prevChapter = currentIndex > 0 ? seriesChapters[currentIndex - 1] : null;
  nextChapter = currentIndex < seriesChapters.length - 1 ? seriesChapters[currentIndex + 1] : null;
}

const isSeriesChapter = !!story.data.series;
const romanNumerals = ['', 'I', 'II', 'III', 'IV', 'V', 'VI', 'VII', 'VIII', 'IX', 'X', 'XI', 'XII'];
const chapterNumeral = story.data.series ? romanNumerals[story.data.series.position] || String(story.data.series.position) : '';
---

<BaseLayout
  title={isSeriesChapter ? `${story.data.series!.title} — ${story.data.title}` : story.data.title}
  description={story.data.excerpt}
  image={story.data.featureImage}
  type="article"
  publishedTime={publishedDate.toISOString()}
  author={story.data.author}
  tags={story.data.tags}
>
  <ReadingProgress client:idle />

  <main class="min-h-screen">
    <SiteHeader currentPage="fiction" />

    <div class="max-w-2xl mx-auto px-4 py-16">
      <!-- Back link -->
      <a
        href="/blog/fiction"
        class="group inline-flex items-center gap-2 text-zinc-500 hover:text-athletic-court-orange transition-all duration-150 text-sm mb-12 no-print"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        All fiction
      </a>

      <article data-pagefind-body>
        {story.data.contentWarnings && story.data.contentWarnings.length > 0 && (
          <aside class="mb-10 p-4 rounded-lg border border-amber-900/40 bg-amber-950/20 text-sm text-amber-200/80">
            <p class="font-semibold uppercase tracking-wider text-xs text-amber-400/80 mb-2">Content notes</p>
            <p>{story.data.contentWarnings.join(', ')}</p>
          </aside>
        )}

        <header class="mb-14 text-center">
          {isSeriesChapter ? (
            <p class="text-xs uppercase tracking-[0.25em] text-zinc-500 mb-8">
              {story.data.series!.title}
              <span class="text-zinc-700 mx-2">&middot;</span>
              <span class="text-zinc-400">Chapter {chapterNumeral}</span>
              {story.data.series!.totalChapters && (
                <span class="text-zinc-700"> / {romanNumerals[story.data.series!.totalChapters] || story.data.series!.totalChapters}</span>
              )}
            </p>
          ) : (
            <p class="text-xs uppercase tracking-[0.25em] text-zinc-500 mb-6">
              {formLabel[story.data.form] || 'Short Story'}
            </p>
          )}

          <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl text-white leading-[1.1] tracking-tight mb-6 text-balance">
            {story.data.title}
          </h1>

          {story.data.excerpt && (
            <p class="font-serif italic text-xl text-zinc-400 leading-relaxed max-w-xl mx-auto mb-6">
              {story.data.excerpt}
            </p>
          )}

          <div class="flex items-center justify-center gap-3 text-xs text-zinc-600 pt-4 border-t border-zinc-900/60 max-w-xs mx-auto">
            <time datetime={publishedDate.toISOString()}>{formattedDate}</time>
            <span class="text-zinc-800">&middot;</span>
            <span>{readingTime} min read</span>
          </div>
        </header>

        {story.data.featureImage && (
          <div class="mb-14 aspect-video overflow-hidden rounded-sm border border-zinc-800/50">
            <img
              src={story.data.featureImage}
              alt={story.data.title}
              class="w-full h-full object-cover"
              width="1200"
              height="675"
              loading="eager"
              decoding="async"
            />
          </div>
        )}

        <div class:list={["fiction-prose", { "with-dropcap": !isSeriesChapter || story.data.series!.position === 1 }]}>
          <Content />
        </div>

        <!-- Chapter navigation -->
        {isSeriesChapter && (prevChapter || nextChapter) && (
          <nav class="mt-20 pt-10 border-t border-zinc-800/50 no-print">
            <div class="grid grid-cols-2 gap-4">
              {prevChapter ? (
                <a href={`/blog/fiction/${prevChapter.id}`} class="group block p-5 rounded-sm border border-zinc-800/60 hover:border-zinc-700 transition-colors text-left">
                  <div class="flex items-center gap-2 text-xs uppercase tracking-wider text-zinc-600 mb-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                    </svg>
                    Previous · Chapter {romanNumerals[prevChapter.data.series!.position] || prevChapter.data.series!.position}
                  </div>
                  <div class="font-serif text-xl text-zinc-300 group-hover:text-white transition-colors">
                    {prevChapter.data.title}
                  </div>
                </a>
              ) : (
                <div></div>
              )}
              {nextChapter ? (
                <a href={`/blog/fiction/${nextChapter.id}`} class="group block p-5 rounded-sm border border-zinc-800/60 hover:border-zinc-700 transition-colors text-right">
                  <div class="flex items-center gap-2 justify-end text-xs uppercase tracking-wider text-zinc-600 mb-2">
                    Next · Chapter {romanNumerals[nextChapter.data.series!.position] || nextChapter.data.series!.position}
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                  </div>
                  <div class="font-serif text-xl text-zinc-300 group-hover:text-white transition-colors">
                    {nextChapter.data.title}
                  </div>
                </a>
              ) : (
                <div></div>
              )}
            </div>
          </nav>
        )}

        <!-- Full chapter list for the series -->
        {isSeriesChapter && seriesChapters.length > 1 && (
          <section class="mt-12 no-print">
            <details class="group">
              <summary class="cursor-pointer text-xs uppercase tracking-[0.2em] text-zinc-600 hover:text-zinc-400 transition-colors list-none flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
                All chapters in {story.data.series!.title}
              </summary>
              <ol class="mt-6 space-y-3">
                {seriesChapters.map((chapter) => {
                  const isCurrent = chapter.id === story.id;
                  return (
                    <li>
                      <a
                        href={`/blog/fiction/${chapter.id}`}
                        class={`flex items-baseline gap-4 py-2 transition-colors ${isCurrent ? 'text-white' : 'text-zinc-500 hover:text-zinc-300'}`}
                      >
                        <span class="font-serif text-xs text-zinc-700 w-8">{romanNumerals[chapter.data.series!.position] || chapter.data.series!.position}</span>
                        <span class="font-serif">{chapter.data.title}</span>
                        {isCurrent && <span class="text-xs text-zinc-700 italic">reading</span>}
                      </a>
                    </li>
                  );
                })}
              </ol>
            </details>
          </section>
        )}

        {!isSeriesChapter && (
          <footer class="mt-20 pt-10 border-t border-zinc-800/50 text-center">
            <p class="text-xs uppercase tracking-[0.2em] text-zinc-600 mb-3">— End —</p>
            <p class="text-sm text-zinc-500">
              {story.data.author || 'Nino Chavez'}
            </p>
            {story.data.tags && story.data.tags.length > 0 && (
              <div class="flex flex-wrap justify-center gap-2 mt-6">
                {story.data.tags.map((tag) => (
                  <span class="text-xs px-3 py-1 rounded-full bg-zinc-900/50 text-zinc-500 border border-zinc-800/50">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </footer>
        )}
      </article>
    </div>

    <SiteFooter />
  </main>
</BaseLayout>

<style is:global>
  .fiction-prose {
    font-family: Georgia, 'Iowan Old Style', 'Palatino Linotype', Palatino, serif;
    font-size: 1.2rem;
    line-height: 1.85;
    color: rgb(228 228 231);
    max-width: 34rem;
    margin: 0 auto;
  }

  .fiction-prose > p {
    margin: 0 0 1.5em 0;
    text-indent: 0;
  }

  .fiction-prose > p + p {
    text-indent: 1.75em;
    margin-top: -0.5em;
  }

  .fiction-prose > p:first-of-type {
    text-indent: 0;
  }

  .fiction-prose.with-dropcap > p:first-of-type::first-letter {
    font-family: Georgia, serif;
    font-size: 4.5em;
    float: left;
    line-height: 0.85;
    padding: 0.1em 0.1em 0 0;
    font-weight: 600;
    color: rgb(255 255 255);
  }

  .fiction-prose > hr {
    border: none;
    text-align: center;
    margin: 2.5em 0;
    color: rgb(113 113 122);
  }

  .fiction-prose > hr::before {
    content: '※';
    font-size: 1.25em;
    letter-spacing: 0.5em;
  }

  .fiction-prose em {
    font-style: italic;
  }

  .fiction-prose blockquote {
    border: none;
    font-style: italic;
    margin: 1.5em 2em;
    color: rgb(161 161 170);
  }

  .fiction-prose details summary::-webkit-details-marker {
    display: none;
  }
</style>
