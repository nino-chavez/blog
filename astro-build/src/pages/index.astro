---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogList from '../components/BlogList';
import { generateWebsiteSchema, generateBlogSchema, generatePersonSchema } from '../utils/schema';

// Get all published posts sorted by date
const posts = await getCollection('blog', ({ data }) => data.status !== 'draft');
const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);

// Prepare posts data for BlogList component
const postsData = sortedPosts.map((post) => ({
  id: post.id,
  title: post.data.title,
  excerpt: post.data.excerpt || '',
  publishedAt: typeof post.data.publishedAt === 'string'
    ? post.data.publishedAt
    : post.data.publishedAt.toISOString(),
  category: post.data.category,
  tags: post.data.tags,
  featured: post.data.featured,
  featureImage: post.data.featureImage,
}));

// Generate JSON-LD schemas
const websiteSchema = generateWebsiteSchema();
const blogSchema = generateBlogSchema(sortedPosts);
const personSchema = generatePersonSchema();
---

<BaseLayout
  title="Signal Dispatch"
  description="Architecture, commerce, and the signals that matter. Exploring AI workflows, systems thinking, and leadership through practical experience."
  jsonLd={[websiteSchema, blogSchema, personSchema]}
>
  <main class="min-h-screen">
    <!-- Compact Header -->
    <header class="sticky top-0 z-50 bg-zinc-950/95 backdrop-blur-xl border-b border-zinc-800/30">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-[73px]">
          <!-- Logo -->
          <a href="/blog" class="flex items-center gap-3">
            <h1 class="text-lg font-bold bg-gradient-to-r from-athletic-brand-violet to-athletic-court-orange bg-clip-text text-transparent">
              Signal Dispatch
            </h1>
            <span class="hidden lg:inline text-sm text-zinc-500">
              · Strategy, insights, and the signals that matter
            </span>
          </a>

          <!-- Right: Links -->
          <div class="flex items-center gap-4">
            <a href="/blog/whitepapers" class="text-sm text-zinc-400 hover:text-white transition-colors">
              Whitepapers
            </a>
            <a href="/blog/rss.xml" class="text-zinc-400 hover:text-white transition-colors" title="RSS Feed">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7m-6 0a1 1 0 11-2 0 1 1 0 012 0z" />
              </svg>
            </a>
            <a href="https://ninochavez.co" target="_blank" rel="noopener noreferrer" class="text-zinc-400 hover:text-white transition-colors" title="Portfolio">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
        </div>
      </nav>
    </header>

    <!-- Blog Content -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <BlogList posts={postsData} client:load />
    </section>

    <!-- Footer -->
    <footer class="border-t border-zinc-800/50 py-12 mt-8">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row justify-between items-center gap-6">
          <div class="text-center md:text-left">
            <p class="text-zinc-500 text-sm">
              &copy; {new Date().getFullYear()} Nino Chavez. All rights reserved.
            </p>
          </div>
          <div class="flex items-center gap-6">
            <a href="/blog/rss.xml" class="text-zinc-400 hover:text-white text-sm transition-colors">RSS Feed</a>
            <a href="/blog/full-content-rss.xml" class="text-zinc-400 hover:text-white text-sm transition-colors">Full RSS</a>
            <a href="/blog/api/posts.json" class="text-zinc-400 hover:text-white text-sm transition-colors">API</a>
            <a href="/blog/llms.txt" class="text-zinc-400 hover:text-white text-sm transition-colors">llms.txt</a>
            <a href="https://ninochavez.co" class="text-zinc-400 hover:text-white text-sm transition-colors">ninochavez.co</a>
          </div>
        </div>
      </div>
    </footer>
  </main>
</BaseLayout>
