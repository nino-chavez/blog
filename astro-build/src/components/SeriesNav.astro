---
import { getCollection } from 'astro:content';

interface Props {
  seriesSlug: string;
  currentPosition: number;
}

const { seriesSlug, currentPosition } = Astro.props;

// Fetch series metadata
const allSeries = await getCollection('series');
const series = allSeries.find((s) => s.id === seriesSlug);

// Fetch all posts in this series
const blogPosts = await getCollection('blog', ({ data }) =>
  data.status === 'published' && data.series?.slug === seriesSlug
);
const sortedPosts = blogPosts.sort((a, b) =>
  (a.data.series?.position || 0) - (b.data.series?.position || 0)
);

const totalPosts = sortedPosts.length;
const prevPost = sortedPosts.find((p) => p.data.series?.position === currentPosition - 1);
const nextPost = sortedPosts.find((p) => p.data.series?.position === currentPosition + 1);
---

{series && (
  <div class="relative overflow-hidden rounded-xl border border-athletic-court-orange/20 bg-zinc-900/80 backdrop-blur-sm mb-10">
    {/* Progress bar at top - visual anchor */}
    <div class="h-1 bg-zinc-800">
      <div
        class="h-full bg-gradient-to-r from-athletic-brand-violet to-athletic-court-orange transition-all duration-300"
        style={`width: ${(currentPosition / totalPosts) * 100}%`}
      />
    </div>

    <div class="p-5 md:p-6">
      {/* Series header - simplified */}
      <div class="flex items-center justify-between gap-4 mb-5">
        <div class="flex items-center gap-2 text-sm">
          <span class="font-bold text-athletic-court-orange">
            Part {currentPosition} of {totalPosts}
          </span>
          <span class="text-zinc-500">in</span>
          <a
            href={`/blog/series/${seriesSlug}`}
            class="font-semibold text-white hover:text-athletic-court-orange transition-colors"
          >
            {series.data.title}
          </a>
        </div>

        <a
          href={`/blog/series/${seriesSlug}`}
          class="text-xs text-zinc-500 hover:text-athletic-brand-violet transition-colors flex items-center gap-1 flex-shrink-0"
        >
          <span class="hidden sm:inline">View full series</span>
          <span class="sm:hidden">Series</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>

      {/* Navigation - stacked on mobile, side-by-side on larger screens */}
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {prevPost ? (
          <a
            href={`/blog/${prevPost.id}`}
            class="group flex items-center gap-3 p-3 rounded-lg bg-zinc-800/40 hover:bg-zinc-800/70 border border-zinc-700/50 hover:border-zinc-600 transition-all"
          >
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-zinc-700/50 flex items-center justify-center group-hover:bg-athletic-brand-violet/20 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-zinc-400 group-hover:text-athletic-brand-violet transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
              </svg>
            </div>
            <div class="min-w-0 flex-1">
              <span class="text-[10px] uppercase tracking-wider text-zinc-500 block mb-0.5">Previous</span>
              <span class="text-sm text-zinc-300 group-hover:text-white transition-colors line-clamp-1">
                {prevPost.data.title}
              </span>
            </div>
          </a>
        ) : (
          <div class="hidden sm:block" />
        )}

        {nextPost ? (
          <a
            href={`/blog/${nextPost.id}`}
            class="group flex items-center gap-3 p-3 rounded-lg bg-zinc-800/40 hover:bg-zinc-800/70 border border-zinc-700/50 hover:border-zinc-600 transition-all sm:flex-row-reverse sm:text-right"
          >
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-zinc-700/50 flex items-center justify-center group-hover:bg-athletic-court-orange/20 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-zinc-400 group-hover:text-athletic-court-orange transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </div>
            <div class="min-w-0 flex-1">
              <span class="text-[10px] uppercase tracking-wider text-zinc-500 block mb-0.5">Next</span>
              <span class="text-sm text-zinc-300 group-hover:text-white transition-colors line-clamp-1">
                {nextPost.data.title}
              </span>
            </div>
          </a>
        ) : (
          <div class="hidden sm:block" />
        )}
      </div>
    </div>
  </div>
)}
