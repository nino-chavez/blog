---
interface Props {
  currentPage?: 'blog' | 'series' | 'tags' | 'whitepapers' | 'presentations' | 'tutorials' | 'counterpoints' | 'research' | 'about';
}

const { currentPage } = Astro.props;

const contentLinks = [
  { href: '/blog/whitepapers', label: 'Whitepapers', id: 'whitepapers' },
  { href: '/blog/presentations', label: 'Presentations', id: 'presentations' },
  { href: '/blog/tutorials', label: 'Tutorials', id: 'tutorials' },
  { href: '/blog/counterpoints', label: 'Counterpoints', id: 'counterpoints' },
];

const discoveryLinks = [
  { href: '/blog/series', label: 'Series', id: 'series' },
  { href: '/blog/tags', label: 'Tags', id: 'tags' },
];

const utilityLinks = [
  { href: '/about', label: 'About', id: 'about' },
];

function linkClasses(id: string, base: string) {
  return currentPage === id
    ? `${base} text-white bg-zinc-800/60 font-medium`
    : `${base} text-zinc-400 hover:text-white`;
}
---

<header class="sticky top-0 z-50 bg-zinc-950/95 backdrop-blur-xl border-b border-zinc-800/30">
  <nav class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14 md:h-[73px]">
      <!-- Logo -->
      <a href="/blog" class="flex items-center gap-3 flex-shrink-0">
        <span class="text-base sm:text-lg font-bold bg-gradient-to-r from-athletic-brand-violet to-athletic-court-orange bg-clip-text text-transparent whitespace-nowrap">
          Signal Dispatch
        </span>
        <span class="hidden xl:inline text-sm text-zinc-500 whitespace-nowrap">
          · Strategy, insights, and the signals that matter
        </span>
      </a>

      <!-- Desktop nav (md+) -->
      <div class="hidden md:flex items-center gap-1">
        <!-- Content links (always visible at md+) -->
        {contentLinks.map((link) => (
          <a
            href={link.href}
            class={linkClasses(link.id, 'text-sm px-2.5 py-1 rounded-md transition-colors')}
          >
            {link.label}
          </a>
        ))}

        <!-- Discovery links (lg+ only) -->
        <span class="hidden lg:inline text-zinc-700 mx-0.5">·</span>
        {discoveryLinks.map((link) => (
          <a
            href={link.href}
            class={linkClasses(link.id, 'hidden lg:block text-sm px-2.5 py-1 rounded-md transition-colors')}
          >
            {link.label}
          </a>
        ))}

        <!-- Utility links -->
        <span class="text-zinc-700 mx-0.5 hidden lg:inline">·</span>
        {utilityLinks.map((link) => (
          <a
            href={link.href}
            class={linkClasses(link.id, 'text-sm px-2.5 py-1 rounded-md transition-colors')}
          >
            {link.label}
          </a>
        ))}

        <!-- Icon divider -->
        <div class="border-l border-zinc-800/50 h-5 mx-2"></div>

        <!-- RSS -->
        <a
          href="/blog/rss.xml"
          class="flex items-center justify-center w-8 h-8 rounded-md text-zinc-400 hover:text-white transition-colors"
          title="RSS Feed"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7m-6 0a1 1 0 11-2 0 1 1 0 012 0z" />
          </svg>
        </a>

        <!-- Portfolio -->
        <a
          href="https://ninochavez.co"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center w-8 h-8 rounded-md text-zinc-400 hover:text-white transition-colors"
          title="ninochavez.co"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>

      <!-- Mobile hamburger button (below md) -->
      <button
        id="mobile-menu-btn"
        type="button"
        class="md:hidden flex items-center justify-center w-10 h-10 rounded-lg text-zinc-400 hover:text-white hover:bg-zinc-800/50 transition-colors"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="sr-only">Open menu</span>
        <!-- Hamburger icon -->
        <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <!-- X icon (hidden by default) -->
        <svg id="menu-icon-close" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<!-- Mobile menu overlay (outside header to avoid backdrop-filter containing block) -->
<div
  id="mobile-menu"
  class="hidden fixed inset-0 top-14 z-[45] bg-zinc-950/98 backdrop-blur-xl md:hidden overflow-y-auto"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
>
  <nav class="max-w-7xl mx-auto px-6 py-8">
    <!-- Content section -->
    <div class="mb-8">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-zinc-500 mb-3">Content</h2>
      <div class="flex flex-col gap-1">
        {contentLinks.map((link) => (
          <a
            href={link.href}
            class={`py-3 px-3 text-lg rounded-lg transition-colors ${
              currentPage === link.id
                ? 'text-white bg-zinc-800/60 font-medium'
                : 'text-zinc-300 hover:text-white hover:bg-zinc-800/30'
            }`}
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>

    <!-- Discover section -->
    <div class="mb-8">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-zinc-500 mb-3">Discover</h2>
      <div class="flex flex-col gap-1">
        {discoveryLinks.map((link) => (
          <a
            href={link.href}
            class={`py-3 px-3 text-lg rounded-lg transition-colors ${
              currentPage === link.id
                ? 'text-white bg-zinc-800/60 font-medium'
                : 'text-zinc-300 hover:text-white hover:bg-zinc-800/30'
            }`}
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>

    <!-- More section -->
    <div>
      <h2 class="text-xs font-semibold uppercase tracking-wider text-zinc-500 mb-3">More</h2>
      <div class="flex flex-col gap-1">
        {utilityLinks.map((link) => (
          <a
            href={link.href}
            class={`py-3 px-3 text-lg rounded-lg transition-colors ${
              currentPage === link.id
                ? 'text-white bg-zinc-800/60 font-medium'
                : 'text-zinc-300 hover:text-white hover:bg-zinc-800/30'
            }`}
          >
            {link.label}
          </a>
        ))}
        <a
          href="/blog/rss.xml"
          class="py-3 px-3 text-lg text-zinc-300 hover:text-white hover:bg-zinc-800/30 rounded-lg transition-colors"
        >
          RSS Feed
        </a>
        <a
          href="https://ninochavez.co"
          target="_blank"
          rel="noopener noreferrer"
          class="py-3 px-3 text-lg text-zinc-300 hover:text-white hover:bg-zinc-800/30 rounded-lg transition-colors"
        >
          ninochavez.co
        </a>
      </div>
    </div>
  </nav>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  function toggleMenu() {
    const isOpen = menu?.classList.contains('hidden') === false;
    if (isOpen) {
      closeMenu();
    } else {
      openMenu();
    }
  }

  function openMenu() {
    menu?.classList.remove('hidden');
    iconOpen?.classList.add('hidden');
    iconClose?.classList.remove('hidden');
    btn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.add('hidden');
    iconOpen?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
    btn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  btn?.addEventListener('click', toggleMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !menu?.classList.contains('hidden')) {
      closeMenu();
    }
  });
</script>
