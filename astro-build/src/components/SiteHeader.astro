---
interface Props {
  currentPage?: 'blog' | 'series' | 'tags' | 'whitepapers' | 'presentations' | 'counterpoints' | 'about';
}

const { currentPage } = Astro.props;

const navLinks = [
  { href: '/blog/series', label: 'Series', id: 'series' },
  { href: '/blog/tags', label: 'Tags', id: 'tags' },
  { href: '/blog/whitepapers', label: 'Whitepapers', id: 'whitepapers' },
  { href: '/blog/presentations', label: 'Presentations', id: 'presentations' },
  { href: '/blog/counterpoints', label: 'Counterpoints', id: 'counterpoints' },
  { href: '/about', label: 'About', id: 'about' },
];

// Icons for mobile nav
const icons: Record<string, string> = {
  series: 'M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10',
  tags: 'M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z',
  whitepapers: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  presentations: 'M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z',
  counterpoints: 'M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3',
  about: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
};
---

<header class="sticky top-0 z-50 bg-zinc-950/95 backdrop-blur-xl border-b border-zinc-800/30">
  <nav class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-[56px] sm:h-[73px]">
      <!-- Logo -->
      <a href="/blog" class="flex items-center gap-2 sm:gap-3 flex-shrink min-w-0">
        <h1 class="text-sm xs:text-base sm:text-lg font-bold bg-gradient-to-r from-athletic-brand-violet to-athletic-court-orange bg-clip-text text-transparent truncate">
          Signal Dispatch
        </h1>
        <span class="hidden lg:inline text-sm text-zinc-500 truncate">
          · Strategy, insights, and the signals that matter
        </span>
      </a>

      <!-- Right: Links -->
      <div class="flex items-center gap-0.5 xs:gap-1 sm:gap-4 flex-shrink-0">
        <!-- Desktop text links -->
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`hidden sm:block text-sm transition-colors ${
              currentPage === link.id
                ? 'text-white font-medium'
                : 'text-zinc-400 hover:text-white'
            }`}
          >
            {link.label}
          </a>
        ))}

        <!-- Mobile icon links -->
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`sm:hidden flex items-center justify-center w-9 h-9 rounded-lg transition-colors ${
              currentPage === link.id
                ? 'text-white bg-zinc-800/50'
                : 'text-zinc-400 hover:text-white hover:bg-zinc-800/50'
            }`}
            title={link.label}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d={icons[link.id]} />
            </svg>
          </a>
        ))}

        <!-- RSS Feed -->
        <a
          href="/rss.xml"
          class="flex items-center justify-center w-9 h-9 sm:w-auto sm:h-auto rounded-lg text-zinc-400 hover:text-white hover:bg-zinc-800/50 sm:hover:bg-transparent transition-colors"
          title="RSS Feed"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7m-6 0a1 1 0 11-2 0 1 1 0 012 0z" />
          </svg>
        </a>

        <!-- Portfolio link -->
        <a
          href="https://ninochavez.co"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center w-9 h-9 sm:w-auto sm:h-auto rounded-lg text-zinc-400 hover:text-white hover:bg-zinc-800/50 sm:hover:bg-transparent transition-colors"
          title="Portfolio"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    </div>
  </nav>
</header>
