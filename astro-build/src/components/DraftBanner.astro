---
interface Props {
  slug: string;
  title: string;
  hasFeatureImage: boolean;
}

const { slug, title, hasFeatureImage } = Astro.props;
---

<div id="draft-banner" class="fixed top-0 left-0 right-0 z-50 bg-amber-500/95 backdrop-blur-sm border-b border-amber-600 shadow-lg print:hidden">
  <div class="max-w-3xl mx-auto px-4 py-3 flex items-center justify-between gap-4 flex-wrap">
    <div class="flex items-center gap-3">
      <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-amber-900/30 text-amber-950 text-xs font-bold uppercase tracking-wider">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
        Draft
      </span>
      <span class="text-amber-950 text-sm font-medium truncate max-w-xs">{title}</span>
    </div>

    <div class="flex items-center gap-2">
      {!hasFeatureImage && (
        <button
          id="generate-image-btn"
          data-slug={slug}
          class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-amber-900/20 text-amber-950 text-sm font-semibold hover:bg-amber-900/30 transition-colors border border-amber-900/30"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          Generate Image
        </button>
      )}
      <button
        id="publish-btn"
        data-slug={slug}
        class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-lg bg-green-700 text-white text-sm font-semibold hover:bg-green-600 transition-colors shadow-sm"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
        Publish
      </button>
    </div>
  </div>

  <!-- Status message area -->
  <div id="draft-banner-status" class="hidden max-w-3xl mx-auto px-4 pb-3">
    <div id="draft-banner-status-inner" class="text-sm text-amber-950 bg-amber-900/10 rounded-md px-3 py-2"></div>
  </div>
</div>

<!-- Spacer to prevent content from hiding behind fixed banner -->
<div class="h-14 print:hidden"></div>

<script>
  function getToken() {
    const params = new URLSearchParams(window.location.search);
    return params.get('token') || '';
  }

  function showStatus(message: string, isError = false) {
    const statusArea = document.getElementById('draft-banner-status');
    const statusInner = document.getElementById('draft-banner-status-inner');
    if (statusArea && statusInner) {
      statusArea.classList.remove('hidden');
      statusInner.textContent = message;
      statusInner.className = `text-sm rounded-md px-3 py-2 ${isError ? 'text-red-900 bg-red-900/20' : 'text-amber-950 bg-amber-900/10'}`;
    }
  }

  async function triggerAction(action: string, slug: string) {
    const token = getToken();
    try {
      const res = await fetch(`/api/${action}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug, token }),
      });
      const data = await res.json();
      if (!res.ok) {
        showStatus(data.error || `Failed to ${action}`, true);
        return false;
      }
      showStatus(data.message || `${action} triggered successfully`);
      return true;
    } catch {
      showStatus(`Network error triggering ${action}`, true);
      return false;
    }
  }

  const publishBtn = document.getElementById('publish-btn');
  if (publishBtn) {
    publishBtn.addEventListener('click', async () => {
      const slug = publishBtn.getAttribute('data-slug') || '';
      publishBtn.setAttribute('disabled', 'true');
      publishBtn.textContent = 'Publishing...';
      showStatus('Triggering publish workflow... This will take a minute.');
      await triggerAction('publish-draft', slug);
    });
  }

  const generateBtn = document.getElementById('generate-image-btn');
  if (generateBtn) {
    generateBtn.addEventListener('click', async () => {
      const slug = generateBtn.getAttribute('data-slug') || '';
      generateBtn.setAttribute('disabled', 'true');
      generateBtn.textContent = 'Generating...';
      showStatus('Triggering image generation... This may take a couple minutes.');
      await triggerAction('generate-image', slug);
    });
  }
</script>
