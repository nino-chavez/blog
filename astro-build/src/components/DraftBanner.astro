---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div id="draft-banner" class="fixed top-0 left-0 right-0 z-50 bg-amber-500/95 backdrop-blur-sm border-b border-amber-600 shadow-lg print:hidden">
  <div class="max-w-3xl mx-auto px-4 py-3 flex items-center gap-3">
    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-amber-900/30 text-amber-950 text-xs font-bold uppercase tracking-wider">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
      </svg>
      Draft
    </span>
    <span class="text-amber-950 text-sm font-medium truncate max-w-xs">{title}</span>
  </div>
</div>

<!-- Spacer to prevent content from hiding behind fixed banner -->
<div class="h-14 print:hidden"></div>
